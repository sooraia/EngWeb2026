extends layout 

block content
  .content
    table#table
      tr
          th Nome
          td= genre.genre
      tr
          th(style="width: 100px") Nº Filmes
          td=genre.films.length
      tr
          th Filmes
          td
            each f in genre.films
              a(href=`/filmes/${f._id}`)
                span.film= f.title
      tr
    footer
      a.button(href=`/genres`) Voltar aos géneros