extends layout 

block content
  .content
    table#table
      tr
          th Título
          td= filme.title
      tr
          th Ano
          td= filme.year
      tr
          th Géneros
          td
            each g in filme.genres
              a(href=`/generos/${encodeURIComponent(g._id)}`)
                span.genre= g.genre
      tr
          th Atores
          td
            each a in filme.cast
              a(href=`/atores/${encodeURIComponent(a._id)}`)
                span.actor= a.actor
    footer
      a.button(href=`/`) Voltar aos filmes